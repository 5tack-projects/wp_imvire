{
  "name": "suraj/project-x",
  "type": "project",

  "repositories": [
    {
      "type": "vcs",
      "url": "git@github.com:5tack-projects/wp_5etup.git"
    }
  ],

  "require": {
    "suraj/wp-5etup": "^1.0"
  },

  "minimum-stability": "dev",
  "prefer-stable": true,

  "scripts": {
    "post-install-cmd": [
      "robocopy vendor\\suraj\\wp-5etup . /E /XD vendor .git /XF composer.json composer.lock /NFL /NDL /NJH /NJS /NC /NS"
    ],
    "post-update-cmd": [
      "robocopy vendor\\suraj\\wp-5etup . /E /XD vendor .git /XF composer.json composer.lock /NFL /NDL /NJH /NJS /NC /NS"
    ]
  }
}