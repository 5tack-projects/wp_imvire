{
  "name": "suraj/project-x",
  "type": "project",

  "repositories": [
    {
      "type": "vcs",
      "url": "git@github.com:5tack-projects/wp_5etup.git"
    }
  ],

  "require-dev": {
    "wp-cli/wp-cli": "^2.8"
  },

  "require": {
    "suraj/wp-5etup": "^1.0"
  },

  "minimum-stability": "dev",
  "prefer-stable": true,

  "scripts": {
    "post-install-cmd": [
      "xcopy vendor\\suraj\\wp-5etup\\* . /E /I /Y"
    ],
    "post-update-cmd": [
      "xcopy vendor\\suraj\\wp-5etup\\* . /E /I /Y"
    ]
  }
}